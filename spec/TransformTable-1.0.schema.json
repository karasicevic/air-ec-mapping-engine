{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TransformTable-1.0 (expanded valueExpr)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "TransformTable-1.0"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "author": {
          "type": "string"
        }
      }
    },
    "codeLists": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entries"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "entries": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source",
                "target"
              ],
              "properties": {
                "source": {
                  "type": "string"
                },
                "target": {
                  "type": [
                    "string",
                    "number",
                    "boolean",
                    "object",
                    "array",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleId",
          "componentId",
          "when",
          "then"
        ],
        "properties": {
          "ruleId": {
            "type": "string",
            "minLength": 1
          },
          "componentId": {
            "type": "string",
            "minLength": 1
          },
          "relevantAxes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "priority": {
            "type": "integer"
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "target"
            ],
            "properties": {
              "source": {
                "$ref": "#/$defs/ContextCondition"
              },
              "target": {
                "$ref": "#/$defs/ContextCondition"
              }
            }
          },
          "matchSource": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "path"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "op": {
                "type": "string",
                "enum": [
                  "equals",
                  "in",
                  "regex",
                  "exists"
                ]
              },
              "value": {}
            }
          },
          "then": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "writes"
            ],
            "properties": {
              "writes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/Write"
                }
              }
            }
          },
          "references": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "standard",
                "id"
              ],
              "properties": {
                "standard": {
                  "type": "string"
                },
                "id": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                }
              }
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "standard",
                "rule"
              ],
              "properties": {
                "standard": {
                  "type": "string"
                },
                "rule": {
                  "type": "string"
                }
              }
            }
          },
          "tests": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "type"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "schematron",
                    "assert",
                    "unit"
                  ]
                },
                "expr": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "ContextCondition": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of axis keys to category tokens, wildcard '*', or placeholder tokens like 'GE.'."
    },
    "Write": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetPath",
        "value"
      ],
      "properties": {
        "targetPath": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/ValueExpr"
        }
      }
    },
    "ValueExpr": {
      "oneOf": [
        {
          "$ref": "#/$defs/LiteralValue"
        },
        {
          "$ref": "#/$defs/SourceValue"
        },
        {
          "$ref": "#/$defs/LookupValue"
        }
      ]
    },
    "LiteralValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "literal"
        },
        "value": {}
      }
    },
    "SourceValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "sourcePath"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "source_value"
        },
        "sourcePath": {
          "type": "string"
        },
        "coerce": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "date",
            "datetime"
          ]
        }
      }
    },
    "LookupValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "tableId",
        "input"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "lookup"
        },
        "tableId": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "$ref": "#/$defs/ValueExpr"
        },
        "onMissing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "error",
                "default"
              ]
            },
            "default": {}
          },
          "required": [
            "action"
          ]
        },
        "default": {}
      }
    }
  }
}